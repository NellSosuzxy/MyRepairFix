# ===============================================
# ENVIRONMENT CONFIGURATION TEMPLATE - MyRepairFix
# ===============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=myrepairfix_db

# Session Configuration
# Generate a random 64-character string for production
SESSION_SECRET=generate_a_random_64_character_string_here

# API Keys
NEWS_API_KEY=your_newsapi_key_here

# Security
# In production, set to your actual domain: https://yourdomain.com
CORS_ORIGIN=http://localhost:3000
